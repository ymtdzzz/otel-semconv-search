{
  "name": "otel-semconv-search",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Fast searchable explorer for OpenTelemetry semantic conventions, with per-version history.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.34.3",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "resolve": "bash scripts/resolve.sh",
    "build:data": "tsx scripts/build-data.ts",
    "data": "pnpm resolve && pnpm build:data",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@astrojs/preact": "^6.0.1",
    "@orama/orama": "^3.1.18",
    "astro": "^7.0.3",
    "marked": "^18.0.5",
    "preact": "^10.29.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@testing-library/preact": "^3.2.4",
    "@types/node": "^26.0.0",
    "happy-dom": "^20.10.6",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
