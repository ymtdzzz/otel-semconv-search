---
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const BASE = import.meta.env.BASE_URL;
const BASE_SLASH = BASE.endsWith("/") ? BASE : `${BASE}/`;
const isDiff = Astro.url.pathname.includes("/diff");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <script is:inline>
      (function () {
        var stored = localStorage.getItem("theme");
        var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        document.documentElement.setAttribute(
          "data-theme",
          stored != null ? stored : prefersDark ? "dark" : "light"
        );
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a href={BASE_SLASH} class="site-logo">OTel Semconv</a>
        <nav class="site-nav">
          <a href={BASE_SLASH} class={`nav-link${!isDiff ? " active" : ""}`}>Search</a>
          <a href={`${BASE_SLASH}diff/`} class={`nav-link${isDiff ? " active" : ""}`}
            >Version Diff</a
          >
        </nav>
        <div class="header-actions">
          <a
            href="https://github.com/ymtdzzz/otel-semconv-search"
            class="gh-link"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub repository"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
              ></path>
            </svg>
          </a>
          <button id="theme-toggle" class="theme-btn" aria-label="Toggle dark/light theme">
            <svg
              class="icon-sun"
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="5"></circle>
              <line x1="12" y1="1" x2="12" y2="3"></line>
              <line x1="12" y1="21" x2="12" y2="23"></line>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
              <line x1="1" y1="12" x2="3" y2="12"></line>
              <line x1="21" y1="12" x2="23" y2="12"></line>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            </svg>
            <svg
              class="icon-moon"
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
          </button>
        </div>
      </div>
    </header>
    <slot />
    <script is:inline>
      (function () {
        var btn = document.getElementById("theme-toggle");
        if (!btn) return;
        btn.addEventListener("click", function () {
          var current = document.documentElement.getAttribute("data-theme");
          var next = current === "dark" ? "light" : "dark";
          document.documentElement.setAttribute("data-theme", next);
          localStorage.setItem("theme", next);
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg: #ffffff;
    --fg: #1b1b1f;
    --muted: #6b7280;
    --line: #e5e7eb;
    --accent: #2563eb;
    --surface: #f9fafb;
    --surface2: #f3f4f6;
    --dep-bg: #fff5f5;
    --dep-border: #fca5a5;
    --dep-border-l: #ef4444;
    color-scheme: light;
  }
  [data-theme="dark"] {
    --bg: #0f1117;
    --fg: #e2e8f0;
    --muted: #8892a4;
    --line: #2d3748;
    --accent: #63b3ed;
    --surface: #1a2035;
    --surface2: #252d40;
    --dep-bg: #1a0a0a;
    --dep-border: #7f1d1d;
    --dep-border-l: #dc2626;
    color-scheme: dark;
  }
  * {
    box-sizing: border-box;
  }
  html,
  body {
    background: var(--bg);
    color: var(--fg);
  }
  body {
    margin: 0;
    font:
      15px/1.5 system-ui,
      -apple-system,
      Segoe UI,
      Roboto,
      sans-serif;
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }
  main {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1.5rem 1rem 4rem;
  }

  /* Header */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg);
    border-bottom: 1px solid var(--line);
    transition: background-color 0.2s ease;
  }
  .site-header-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1rem;
    height: 52px;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .site-logo {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--fg);
    text-decoration: none;
    white-space: nowrap;
  }
  .site-nav {
    display: flex;
    gap: 0.25rem;
    flex: 1;
  }
  .nav-link {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.9rem;
    padding: 0.3rem 0.6rem;
    border-radius: 6px;
    white-space: nowrap;
    transition:
      color 0.15s,
      background 0.15s;
  }
  .nav-link:hover {
    color: var(--fg);
    background: var(--surface2);
  }
  .nav-link.active {
    color: var(--fg);
    font-weight: 500;
  }
  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }
  @media (max-width: 400px) {
    .site-header-inner {
      padding: 0 0.5rem;
      gap: 0.5rem;
    }
    .nav-link {
      padding: 0.3rem 0.35rem;
    }
  }
  .gh-link {
    color: var(--muted);
    display: flex;
    align-items: center;
    transition: color 0.15s;
  }
  .gh-link:hover {
    color: var(--fg);
  }
  .theme-btn {
    background: none;
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 0.3rem;
    color: var(--muted);
    cursor: pointer;
    display: flex;
    align-items: center;
    transition:
      color 0.15s,
      border-color 0.15s;
  }
  .theme-btn:hover {
    color: var(--fg);
    border-color: var(--muted);
  }
  .icon-sun {
    display: none;
  }
  [data-theme="dark"] .icon-sun {
    display: block;
  }
  [data-theme="dark"] .icon-moon {
    display: none;
  }

  /* Badges */
  .badge {
    font-size: 0.72rem;
    padding: 0.05rem 0.4rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    white-space: nowrap;
  }
  .badge.kind {
    background: var(--surface2);
  }
  .badge.stab-stable {
    background: #dcfce7;
    border-color: #86efac;
    color: #14532d;
  }
  .badge.stab-release_candidate {
    background: #e0f2fe;
    border-color: #7dd3fc;
    color: #0c4a6e;
  }
  .badge.stab-development {
    background: #fef9c3;
    border-color: #fde047;
    color: #713f12;
  }
  .badge.stab-alpha,
  .badge.stab-beta {
    background: #fae8ff;
    border-color: #e9d5ff;
    color: #581c87;
  }
  .badge.dep {
    background: #ffedd5;
    border-color: #fdba74;
    color: #7c2d12;
  }
  .badge.rm {
    background: #fee2e2;
    border-color: #fca5a5;
    color: #7f1d1d;
  }

  [data-theme="dark"] .badge.kind {
    background: var(--surface2);
    color: var(--fg);
  }
  [data-theme="dark"] .badge.stab-stable {
    background: #052e16;
    border-color: #166534;
    color: #4ade80;
  }
  [data-theme="dark"] .badge.stab-release_candidate {
    background: #0c1a2e;
    border-color: #1d4ed8;
    color: #7dd3fc;
  }
  [data-theme="dark"] .badge.stab-development {
    background: #1c1204;
    border-color: #854d0e;
    color: #fde047;
  }
  [data-theme="dark"] .badge.stab-alpha,
  [data-theme="dark"] .badge.stab-beta {
    background: #1a0833;
    border-color: #6b21a8;
    color: #c084fc;
  }
  [data-theme="dark"] .badge.dep {
    background: #1c0f00;
    border-color: #92400e;
    color: #fb923c;
  }
  [data-theme="dark"] .badge.rm {
    background: #1c0000;
    border-color: #991b1b;
    color: #f87171;
  }

  /* Form elements */
  [data-theme="dark"] input,
  [data-theme="dark"] select,
  [data-theme="dark"] textarea {
    background: var(--surface);
    color: var(--fg);
    border-color: var(--line);
  }
</style>
